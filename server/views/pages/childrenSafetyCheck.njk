{% extends "partials/layout.njk" %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "macros/title.njk" import getTitle with context %}

{% block pageTitle %}
  {{ getTitle(formFields.CHILDREN_SAFETY_CHECK, errors) }}
{% endblock %}

{% block content %}
  {% include "partials/exitThisPage.njk" %}
  <div class="govuk-visually-hidden" role="status" aria-live="polite" aria-atomic="true">
    {{ __('exitThisPage') | safe }}
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% include "partials/errorSummary.njk" %}
      <h1 class="govuk-heading-l">{{ title }}</h1>

      <p>{{ __('childrenSafetyCheck.childrenMayBeAtRisk') }}</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>{{ __('childrenSafetyCheck.domesticAbuse') }}</li>
        <li>{{ __('childrenSafetyCheck.childAbduction') }}</li>
        <li>{{ __('childrenSafetyCheck.childAbuse') }}</li>
        <li>{{ __('childrenSafetyCheck.drugsOrAlcohol') }}</li>
        <li>{{ __('childrenSafetyCheck.otherConcerns') }}</li>
      </ul>

      <form class="form" action="{{ paths.CHILDREN_SAFETY_CHECK }}?lang={{ getLocale() }}" method="post" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        {{
          govukRadios({
            name: formFields.CHILDREN_SAFETY_CHECK,
            fieldset: {
              legend: {
                text: __('childrenSafetyCheck.questionTitle'),
                isPageHeading: false,
                classes: "govuk-fieldset__legend--m"
              }
            },
            items: [
              {
                value: "Yes",
                text: __('yes')
              },
              {
                value: "No",
                text: __('no')
              }
            ],
            errorMessage: errors | findError(formFields.CHILDREN_SAFETY_CHECK)
          })
        }}
        {{ govukButton({text: __('continue')}) }}
      </form>
    </div>
  </div>
{% endblock %}
