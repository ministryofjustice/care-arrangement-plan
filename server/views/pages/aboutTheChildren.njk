{% extends "partials/layout.njk" %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "macros/title.njk" import getTitle with context %}

{% block pageTitle %}
  {{
    getTitle(
      errors,
      'aboutTheChildren',
      [formFields.CHILD_NAME]
    )
  }}
{% endblock %}

{% block content %}
  {% include "partials/exitThisPage.njk" %}
  <div class="govuk-visually-hidden" role="status" aria-live="polite" aria-atomic="true">
    {{ __('exitThisPage') | safe }}
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% include "partials/errorSummary.njk" %}

      <h1 class="govuk-heading-l">
        {{ __('aboutTheChildren.singleTitle') if numberOfChildren === 1 else __('aboutTheChildren.multipleTitle') }}
      </h1>

      <p>{{ __('about.notStoreInfo') }}</p>

      <form class="form" action="{{ paths.ABOUT_THE_CHILDREN }}?lang={{ getLocale() }}" method="post" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        {% for i in range(numberOfChildren) %}
          {% set fieldName = formFields.CHILD_NAME + i %}
          {{
            govukInput({
              name: fieldName,
              label: {
                text: __('aboutTheChildren.singleFirstName') if numberOfChildren === 1 else __('aboutTheChildren.multipleFirstName' + i)
              },
              value: formValues[fieldName],
              errorMessage: errors | findError(fieldName)
            })
          }}
        {% endfor %}
        {{ govukButton({text: __('continue')}) }}
      </form>
    </div>
  </div>
{% endblock %}
