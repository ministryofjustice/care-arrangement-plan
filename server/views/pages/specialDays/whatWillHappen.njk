{% extends "partials/layout.njk" %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "macros/title.njk" import getTitle with context %}

{% block pageTitle %}
  {{
    getTitle(
      errors,
      titleIds.SPECIAL_DAYS,
      [formFields.SPECIAL_DAYS]
    )
  }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% include "partials/errorSummary.njk" %}

      <form class="form" action="{{ paths.SPECIAL_DAYS_WHAT_WILL_HAPPEN }}?lang={{ getLocale() }}" method="post" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        {{
          govukTextarea({
            label: {
              text: __('specialDays.whatWillHappen.title'),
              classes: "govuk-label--l",
              isPageHeading: true
            },
            hint: {
              text: __('specialDays.whatWillHappen.content')
            },
            name: formFields.SPECIAL_DAYS,
            value: initialWhatWillHappen,
            errorMessage: errors | findError(formFields.SPECIAL_DAYS)
          })
        }}

        <div class="govuk-!-margin-bottom-2"><button type="submit" formaction="{{ paths.SPECIAL_DAYS_WHAT_WILL_HAPPEN_NOT_REQUIRED }}" class="govuk-link link-styled-button">{{ __('doNotNeedToDecideSpecialDays') }}</button></div>
        {{ govukButton({text: __('continue')}) }}
      </form>
    </div>
  </div>
{% endblock %}
