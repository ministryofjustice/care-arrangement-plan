{% extends "partials/layout.njk" %}
{% from "govuk/components/exit-this-page/macro.njk" import govukExitThisPage %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "macros/title.njk" import getTitle with context %}

{% block pageTitle %}
  {{
    getTitle(
      null,
      titleIds.CHILDREN_NOT_SAFE
    )
  }}
{% endblock %}

{% block content %}
  {% include "partials/exitThisPage.njk" %}
  <div class="govuk-visually-hidden" role="status" aria-live="polite" aria-atomic="true">
    {{ __('exitThisPage') | safe }}
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ __('childrenNotSafe.title') }}</h1>

      <p class="govuk-body">
        {{ __("childrenNotSafe.content.mayNotBeAppropriate") }}
      </p>

      {{ govukWarningText({
        text: __('childrenNotSafe.content.warningText'),
        iconFallbackText: __('childrenNotSafe.warningIconFallback')
      }) }}

      <p class="govuk-body">
        {{ __("childrenNotSafe.content.continueDescription") }}
      </p>

      {{ govukButton({
        text: __("continue"),
        href: paths.DO_WHATS_BEST,
        classes: "govuk-button--primary"
      }) }}

      <h2 class="govuk-heading-m">
        {{ __("childrenNotSafe.content.getHelpProtecting.title") }}
      </h2>
      <p class="govuk-body">
        {{ __("childrenNotSafe.content.getHelpProtecting.importantToRemember") }}
      </p>
      <p class="govuk-body">
        {{ __("childrenNotSafe.content.getHelpProtecting.experiencedAbuse") | safe }}
      </p>
      <p class="govuk-body">
        {{ __("childrenNotSafe.content.getHelpProtecting.findOut") | safe }}
      </p>

      <h2 class="govuk-heading-m">
        {{ __("childrenNotSafe.content.helpAndSupport.title") }}
      </h2>
      <p class="govuk-body">
        {{ __("childrenNotSafe.content.helpAndSupport.description") }}
      </p>

      <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key govuk-summary-list__key-mediation-width">
          </dt>
          <dd class="govuk-summary-list__value">
          </dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key govuk-summary-list__key-mediation-width">
            {{ __("childrenNotSafe.content.helpAndSupport.table.rowOne.heading") | safe }}
          </dt>
          <dd class="govuk-summary-list__value">
            {{ __("childrenNotSafe.content.helpAndSupport.table.rowOne.data") | safe }}
          </dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key govuk-summary-list__key-mediation-width">
            {{ __("childrenNotSafe.content.helpAndSupport.table.rowTwo.heading") | safe }}
          </dt>
          <dd class="govuk-summary-list__value">
            {{ __("childrenNotSafe.content.helpAndSupport.table.rowTwo.data") | safe }}
          </dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key govuk-summary-list__key-mediation-width">
            {{ __("childrenNotSafe.content.helpAndSupport.table.rowThree.heading") | safe }}
          </dt>
          <dd class="govuk-summary-list__value">
            {{ __("childrenNotSafe.content.helpAndSupport.table.rowThree.data") | safe }}
          </dd>
        </div>
      </dl>
    </div>
  </div>
{% endblock %}
