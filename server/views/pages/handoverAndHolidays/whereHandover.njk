{% extends "partials/layout.njk" %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% include "partials/errorSummary.njk" %}
      <form class="form" action="{{ paths.HANDOVER_HOLIDAYS_WHERE_HANDOVER }}" method="post" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        {% set hintHtml %}
          <p>{{ __('handoverAndHolidays.whereHandover.explainer') }}</p>
          <p>{{ __('selectAllThatApply') }}</p>
        {% endset -%}

        {% set anotherHtml %}
          {{
            govukTextarea({
              name: formFields.WHERE_HANDOVER_OTHER,
              label: {
                text: __('handoverAndHolidays.whereHandover.otherLabel')
              },
              value: formValues[formFields.WHERE_HANDOVER_OTHER],
              errorMessage: errors | findError(formFields.WHERE_HANDOVER_OTHER)
            })
          }}
        {% endset -%}

        {{
          govukCheckboxes({
            name: formFields.WHERE_HANDOVER,
            fieldset: {
              legend: {
                text: title,
                isPageHeading: true,
                classes: "govuk-fieldset__legend--l"
              }
            },
            hint: {
              html: hintHtml
            },
            items: [
              {
                value: "neutral",
                text: __('handoverAndHolidays.whereHandover.neutralLocation')
              },
              {
                value: "initialHome",
                text: __('handoverAndHolidays.whereHandover.atHome', {adult: values.initialAdultName})
              },
              {
                value: "secondaryHome",
                text: __('handoverAndHolidays.whereHandover.atHome', {adult: values.secondaryAdultName})
              },
              {
                value: "school",
                text: __('handoverAndHolidays.whereHandover.atSchool')
              },
              {
                value: "other",
                text: __('handoverAndHolidays.whereHandover.other'),
                conditional: {
                  html: anotherHtml
                }
              }
            ],
            values: formValues[formFields.WHERE_HANDOVER],
            errorMessage: errors | findError(formFields.WHERE_HANDOVER)
          })
        }}
        <div class="govuk-!-margin-bottom-2"><button type="submit" formaction="{{ paths.HANDOVER_HOLIDAYS_WHERE_HANDOVER_NOT_REQUIRED }}" class="govuk-link link-styled-button">{{ __('doNotNeedToDecideHandoverLocation') }}</button></div>
        {{ govukButton({text: __('continue')}) }}
      </form>
    </div>
  </div>
{% endblock %}
