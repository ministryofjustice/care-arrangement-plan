{% extends "partials/layout.njk" %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "macros/title.njk" import getTitle with context %}

{% block pageTitle %}
  {{
    getTitle(
      errors,
      'handoverAndHolidays.itemsForChangeover',
      [formFields.ITEMS_FOR_CHANGEOVER]
    )
  }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% include "partials/errorSummary.njk" %}
      <form class="form" action="{{ paths.HANDOVER_HOLIDAYS_ITEMS_FOR_CHANGEOVER }}?lang={{ getLocale() }}" method="post" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        {{
          govukTextarea({
            label: {
              text: __('handoverAndHolidays.itemsForChangeover.title'),
              classes: "govuk-label--l",
              isPageHeading: true
            },
            hint: {
              text: __('handoverAndHolidays.itemsForChangeover.content')
            },
            name: formFields.ITEMS_FOR_CHANGEOVER,
            value: initialItemsForChangeover,
            errorMessage: errors | findError(formFields.ITEMS_FOR_CHANGEOVER)
          })
        }}
        <div class="govuk-!-margin-bottom-2"><button type="submit" formaction="{{ paths.HANDOVER_HOLIDAYS_ITEMS_FOR_CHANGEOVER_NOT_REQUIRED }}" class="govuk-link link-styled-button">{{ __('doNotNeedToDecideItemsForChangeover') }}</button></div>
        {{ govukButton({text: __('continue')}) }}
      </form>
    </div>
  </div>
{% endblock %}
