{% extends "partials/layout.njk" %}
{% from "govuk/components/exit-this-page/macro.njk" import govukExitThisPage %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "macros/title.njk" import getTitle with context %}

{% block pageTitle %}
  {{
    getTitle(null, 'notSafe')
  }}
{% endblock %}

{% block content %}
  {% include "partials/exitThisPage.njk" %}
  <div class="govuk-visually-hidden" role="status" aria-live="polite" aria-atomic="true">
    {{ __('exitThisPage') | safe }}
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ __('notSafe.title') }}</h1>

      {{ __('notSafe.intro') | safe }}

      {{ govukWarningText({
        text: __('notSafe.warningText'),
        iconFallbackText: __('notSafe.warningIconFallback')
      }) }}

      {{ __('notSafe.content') | safe }}

      <h2 class="govuk-heading-m">{{ __('notSafe.continueTitle') }}</h2>

      <p>{{ __('notSafe.continue') }}</p>

      <a href="{{ paths.CHILDREN_SAFETY_CHECK }}" role="button" draggable="false" class="govuk-button" data-module="govuk-button">
        {{ __('continue') }}
      </a>
    </div>
  </div>
{% endblock %}
